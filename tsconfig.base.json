{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "noImplicitOverride": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "useUnknownInCatchVariables": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "paths": {
      "@botc/domain-core": ["./packages/domain-core/src/index.ts"],
      "@botc/application": ["./packages/application/src/index.ts"],
      "@botc/assignment-engine": ["./packages/assignment-engine/src/index.ts"],
      "@botc/rules-snv": ["./packages/rules-snv/src/index.ts"],
      "@botc/task-engine": ["./packages/task-engine/src/index.ts"],
      "@botc/information-engine": ["./packages/information-engine/src/index.ts"],
      "@botc/projections": ["./packages/projections/src/index.ts"],
      "@botc/setup-engine": ["./packages/setup-engine/src/index.ts"],
      "@botc/test-harness": ["./packages/test-harness/src/index.ts"]
    }
  }
}
